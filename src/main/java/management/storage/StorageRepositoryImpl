package management.storage;

import lombok.extern.slf4j.Slf4j;
import org.springframework.beans.factory.annotation.Qualifier;
import org.springframework.jdbc.core.JdbcTemplate;
import org.springframework.jdbc.core.PreparedStatementCallback;
import org.springframework.stereotype.Repository;

import java.util.List;

@Slf4j
@Repository
public class StorageRepositoryImpl implements StorageRepository {

    private final JdbcTemplate jdbcTemplate;
    private final JdbcTemplate managementJdbcTemplate;
    public StorageRepositoryImpl(@Qualifier("jdbcTemplate") JdbcTemplate jdbcTemplate,
                                 @Qualifier("managementJdbcTemplate") JdbcTemplate managementJdbcTemplate) {
        this.jdbcTemplate = jdbcTemplate;
        this.managementJdbcTemplate = managementJdbcTemplate;
    }

    private boolean isValidIdentifier(String s) {
        return s != null && s.matches("[a-zA-Z0-9_]+");
    }

    @Override
    public List<String> findTables(String schema) {
        String sql = """
            SELECT tablename
            FROM pg_tables
            WHERE schemaname = ?
        """;
        return jdbcTemplate.queryForList(sql, String.class, schema);
    }


    @Override
    public void dropChunks(String schema, String table, int retentionDays) {
        if (!isValidIdentifier(schema) || !isValidIdentifier(table)) {
            throw new IllegalArgumentException("Invalid schema or table name");
        }
        String qualified = schema + "." + table;
        String sql = "SELECT drop_chunks(?::regclass, (? || ' days')::interval)";
        jdbcTemplate.execute(sql, (PreparedStatementCallback<Void>) ps -> {
            ps.setString(1, qualified);
            ps.setString(2, String.valueOf(retentionDays));
            ps.execute();
            return null;
        });
    }

    @Override
    public int deleteOldestBatch(String schema, String table, int batchSize) {
        if (!isValidIdentifier(schema) || !isValidIdentifier(table)) {
            throw new IllegalArgumentException("Invalid schema or table name");
        }
        String qualified = schema + "." + table;
        String sql = String.format("""
            DELETE FROM %s
            WHERE ctid IN (
                SELECT ctid FROM %s
                ORDER BY created_dt ASC
                LIMIT ?
            )
        """, qualified, qualified);
        return jdbcTemplate.update(sql, batchSize);
    }

    @Override
    public void executeCheckpoint(String sql) {
        jdbcTemplate.execute(sql);
    }


    @Override
    public List<String> showChunksOlderThan(String schema, String table, int days) {
        String qualified = schema + "." + table;
        String sql = "SELECT show_chunks(?::regclass, older_than => (? || ' days')::interval)";
        return jdbcTemplate.queryForList(sql, String.class, qualified, days);
    }

    @Override
    public void vacuumTable(String schema, String table) {
        if (!isValidIdentifier(schema) || !isValidIdentifier(table)) {
            throw new IllegalArgumentException("Invalid schema or table name");
        }
        String sql = String.format("VACUUM %s.%s", schema, table);
        jdbcTemplate.execute(sql);
    }

    @Override
    public double[] findThresholdsByType(int type) {
        String sql = """
            SELECT warn_value, critical_value
              FROM onboard.hw_critical
             WHERE type = ?
               AND use_yn = 0
             ORDER BY hw_critical_sno DESC
             LIMIT 1
            """;
        try {
            return managementJdbcTemplate.queryForObject(sql, (rs, rowNum) -> {
                double warnValue = rs.getDouble("warn_value");
                double criticalValue = rs.getDouble("critical_value");
                return new double[]{warnValue, criticalValue};
            }, type);
        } catch (org.springframework.dao.EmptyResultDataAccessException e) {
            log.warn("No hw_critical row found for type={}", type);
            return null;
        } catch (Exception e) {
            log.error("Failed to fetch thresholds for type={}: {}", type, e.getMessage(), e);
            return null;
        }
    }

}
