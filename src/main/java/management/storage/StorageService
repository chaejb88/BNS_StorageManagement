package management.storage;

import lombok.RequiredArgsConstructor;
import lombok.extern.slf4j.Slf4j;
import org.springframework.stereotype.Service;

import java.io.IOException;
import java.nio.file.FileStore;
import java.nio.file.FileSystems;
import java.nio.file.Files;
import java.nio.file.Path;
import java.util.List;

@Slf4j
@Service
@RequiredArgsConstructor
public class StorageService {

    private final StorageConfig config;
    private final StorageRepository repository;

    private static final String LOCK_KEY = "storage-cleanup-lock";

    public double getUsagePercent() {
        String pathStr = config.getDiskPath();
        try {
            Path path = FileSystems.getDefault().getPath(pathStr);
            FileStore store = Files.getFileStore(path);
            long total = store.getTotalSpace();
            long usable = store.getUsableSpace();
            long used = total - usable;
            return total == 0 ? 0.0 : (used * 100.0 / total);
        } catch (IOException e) {
            log.error("Failed to get FileStore for {}: {}", pathStr, e.getMessage());
            // fallback to 0 to avoid accidental deletion if measurement fails
            return 0.0;
        }
    }

    public void checkStorage() throws InterruptedException {
        // Try to acquire advisory lock to prevent concurrent runs
        boolean locked = false;
        try {
            locked = repository.tryAcquireLock(LOCK_KEY);
            if (!locked) {
                log.info("Another cleanup is running. Exiting.");
                return;
            }

            double usage = getUsagePercent();
            double t1 = config.getThreshold1();
            double t2 = config.getThreshold2();

            log.info("Disk usage: {}%", String.format("%.2f", usage));

            if (usage < t1) {
                log.info("[OK] Disk usage ({}%) is below threshold1 ({}%). No cleanup required.",
                        String.format("%.2f", usage), t1);
                return;
            }

            if (usage >= t1 && usage < t2) {
                log.warn("[WARNING] Disk usage {}% >= threshold1 {}%", usage, t1);
                return;
            }

            if (usage >= t2) {
                log.error("[CRITICAL] Disk usage {}% >= threshold2 {}%", usage, t2);
                cleanupUntilThreshold1();
                runCheckpoint();
            }
        } finally {
            if (locked) {
                repository.releaseLock(LOCK_KEY);
            }
        }
    }

    private void runCheckpoint() {
        try {
            repository.executeCheckpoint("CHECKPOINT");
            log.info("CHECKPOINT executed.");
        } catch (Exception e) {
            log.warn("CHECKPOINT failed: {}", e.getMessage());
        }
    }


    private void cleanupUntilThreshold1() throws InterruptedException {
        double usage = getUsagePercent();
        double target = config.getThreshold1();
        int retention = config.getDefaultRetentionDays();

        List<String> tables = repository.findTables(config.getSchema());

        int iteration = 0;
        boolean forceDeleteMode = false;

        while (usage > target) {
            log.info("Cleanup iteration {} | retentionDays={} | usage={} | target={} | forceDeleteMode={}",
                    iteration, retention, usage, target, forceDeleteMode);

            boolean anyDeletedThisIteration = false;

            for (String table : tables) {
                if (table == null || table.isBlank()) continue;

                try {
                    // 1) 먼저 삭제 대상 존재 여부 확인
                    int candidates = repository.countRowsOlderThan(config.getSchema(), table, retention);
                    if (candidates == 0 && !forceDeleteMode) {
                        log.info("No rows older than {} days in {}.{}. Skipping drop_chunks.", retention, config.getSchema(), table);
                        continue;
                    }

                    if (!forceDeleteMode) {
                        // show_chunks로 청크 존재 확인 (선택적)
                        List<String> chunks = repository.showChunksOlderThan(config.getSchema(), table, retention);
                        if (chunks == null || chunks.isEmpty()) {
                            log.info("No chunks older than {} days for {}.{}. Skipping drop_chunks.", retention, config.getSchema(), table);
                        } else {
                            repository.dropChunks(config.getSchema(), table, retention);
                            log.info("drop_chunks executed on {}.{} (chunks removed: {})", config.getSchema(), table, chunks.size());
                            anyDeletedThisIteration = true;
                        }
                    } else {
                        // force delete: 배치 삭제
                        int deleted = repository.deleteOldestBatch(config.getSchema(), table, config.getBatchSize());
                        log.info("Force deleted {} rows from {}.{}", deleted, config.getSchema(), table);
                        if (deleted > 0) anyDeletedThisIteration = true;
                    }
                } catch (Exception e) {
                    log.warn("Error processing {}.{}: {}. Continue.", config.getSchema(), table, e.getMessage());
                }

                // 목표 달성 시 조기 종료
                usage = getUsagePercent();
                if (usage <= target) break;
            }

            if (!anyDeletedThisIteration && !forceDeleteMode) {
                log.warn("No data deleted in this iteration with retentionDays {}. Switching to FORCE DELETE mode.", retention);
                forceDeleteMode = true;
                continue;
            }

            if (!anyDeletedThisIteration && forceDeleteMode) {
                log.warn("No more data to delete even in FORCE DELETE mode. Stopping cleanup.");
                break;
            }

            Thread.sleep(5000);
            usage = getUsagePercent();
            log.info("After iteration {}, current disk usage: {}%", iteration, String.format("%.2f", usage));

            if (!forceDeleteMode) {
                retention = Math.max(1, retention / 2);
            }

            iteration++;
        }

        log.info("Cleanup finished. Current usage: {}%", String.format("%.2f", getUsagePercent()));
    }

}
