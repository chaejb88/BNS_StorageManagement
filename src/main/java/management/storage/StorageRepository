package management.storage;

import java.time.LocalDateTime;
import java.util.List;

public interface StorageRepository {

    // Query all tables in a schema
    List<String> findTables(String schema);

    // Run TimescaleDB drop_chunks
    void dropChunks(String table, int retentionDays);

    // Generic PostgreSQL DELETE fallback
    int deleteOldData(String table, LocalDateTime cutoff);

    // Find the oldest timestamp
    LocalDateTime findOldestTimestamp(String table);

    // Delete the oldest batch of data
    int deleteOldestBatch(String table, int batchSize);

    // Run checkpoint
    void executeCheckpoint(String sql);


}
