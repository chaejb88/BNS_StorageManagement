package management.storage;

import java.util.List;

/**
 * StorageRepository
 *
 * DB 상의 테이블/청크 관리를 위한 추상 인터페이스입니다.
 * 구현체는 JDBC를 통해 Postgres/TimescaleDB 관련 작업을 수행합니다.
 *
 * 메서드 설명 요약:
 * - findTables: 지정 스키마의 테이블 목록 조회
 * - dropChunks: TimescaleDB의 drop_chunks 호출로 오래된 청크 제거
 * - deleteOldestBatch: 테이블에서 가장 오래된 레코드들을 배치 단위로 삭제
 * - executeCheckpoint: 임의의 SQL 실행 (예: CHECKPOINT)
 * - showChunksOlderThan: 오래된 청크 목록 조회
 */
public interface StorageRepository {

    List<String> findTables(String schema);

    void dropChunks(String schema, String table, int retentionDays);

    int deleteOldestBatch(String schema, String table, int batchSize);

    void executeCheckpoint(String sql);

    List<String> showChunksOlderThan(String schema, String table, int days);

    void vacuumTable(String schema, String table);

    double[] findThresholdsByType(int type);

}
